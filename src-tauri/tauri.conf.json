{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SnippetFlow",
  "version": "../package.json",
  "identifier": "com.snippetflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SnippetFlow",
        "width": 1200,
        "height": 850,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "alwaysOnTop": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["ja-JP"]
      },
      "nsis": {
        "languages": ["Japanese"]
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
